# Secrets and connection strings only — everything else is in config.yml

# Neo4j Knowledge Graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=shittytoken_dev

# GPU Providers
VASTAI_API_KEY=
RUNPOD_API_KEY=

# Hugging Face
HUGGINGFACE_TOKEN=

# Agent LLM (PydanticAI — OOM reasoning, config proposals, all agent decisions)
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-opus-4-6

# Gateway
GATEWAY_ADMIN_TOKEN=

# PostgreSQL (billing)
DATABASE_URL=postgresql://shittytoken:shittytoken_dev@localhost:5432/shittytoken

# Redis (billing cache + state store + sessions)
REDIS_URL=redis://localhost:6379/0

# Billing infrastructure (only needed if gateway.auth.enabled)
# BILLING_POSTGRES_DSN=postgresql://localhost/shittytoken
# BILLING_REDIS_URL=redis://localhost:6379/0
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Web session
WEB_SESSION_SECRET=change-me-in-production

# SSH
SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa
