# Neo4j Knowledge Graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=shittytoken_dev

# GPU Providers
VASTAI_API_KEY=
RUNPOD_API_KEY=

# Anthropic (OOM reasoning)
ANTHROPIC_API_KEY=
OOM_REASONING_MODEL=claude-opus-4-6

# Gateway
GATEWAY_ROUTER_URL=http://localhost:8001
GATEWAY_ADMIN_TOKEN=

# SSH
SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa
SSH_KEEPALIVE_INTERVAL=30

# Orchestrator scaling thresholds
SCALE_UP_WAITING_THRESHOLD=10
SCALE_DOWN_IDLE_SECONDS=300
SCALE_DOWN_CACHE_MAX=0.50

# Benchmark
BENCHMARK_MIN_THROUGHPUT_TPS=20.0

# Monitoring intervals (seconds)
METRICS_POLL_INTERVAL_S=10
HEALTH_CHECK_INTERVAL_S=30
STARTUP_MONITOR_TIMEOUT_S=600
