# Secrets and connection strings only — everything else is in config.yml

# Neo4j Knowledge Graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=shittytoken_dev

# GPU Providers
VASTAI_API_KEY=
RUNPOD_API_KEY=

# Hugging Face
HUGGINGFACE_TOKEN=

# Agent LLM (PydanticAI — OOM reasoning, config proposals, all agent decisions)
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-opus-4-6

# Gateway
GATEWAY_ADMIN_TOKEN=

# Stripe (billing — optional, only needed if gateway.billing.stripe_sync_enabled)
STRIPE_SECRET_KEY=

# SSH
SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa
